# ---------------------------------------------------------------------------
# openConv environment configuration
#
# Every variable is build-time inlined into the client bundle and therefore
# MUST be prefixed with NEXT_PUBLIC_. openConv has no server runtime that
# touches user data — these only configure client-side observability and the
# location of the (lazily loaded) ffmpeg WebAssembly core.
# ---------------------------------------------------------------------------

# --- OpenTelemetry ---------------------------------------------------------

# Master switch for the OpenTelemetry pipeline. When false, a no-op provider
# is installed and nothing is exported.
NEXT_PUBLIC_OTEL_ENABLED=true

# Logical service name reported on every span and log record (service.name).
NEXT_PUBLIC_OTEL_SERVICE_NAME=openconv-web

# Deployment environment (deployment.environment.name resource attribute).
NEXT_PUBLIC_OTEL_ENVIRONMENT=development

# Mirror spans and logs to the browser console. Handy in development; leave
# off in production to avoid noisy output.
NEXT_PUBLIC_OTEL_CONSOLE=true

# OTLP/HTTP collector base endpoint (e.g. https://collector.example.com).
# When empty, no network exporter is registered and telemetry stays local.
NEXT_PUBLIC_OTEL_OTLP_ENDPOINT=

# Minimum log severity to emit: debug | info | warn | error
NEXT_PUBLIC_LOG_LEVEL=info

# --- Media converter (ffmpeg.wasm) ----------------------------------------

# Base URL the single-threaded ffmpeg core is fetched from at runtime.
# Defaults to the official unpkg CDN. Point this at a self-hosted copy for
# offline / air-gapped deployments.
NEXT_PUBLIC_FFMPEG_CORE_URL=https://unpkg.com/@ffmpeg/core@0.12.10/dist/umd
